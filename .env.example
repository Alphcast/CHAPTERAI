# ── Database ──────────────────────────────────────────────
# Prisma connects to PostgreSQL. Use your Supabase project's
# connection strings from Project Settings → Database.
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres"

# ── Supabase (optional — for Storage / realtime) ─────────
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT_REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[YOUR_ANON_KEY]"

# ── AI Providers (at least one required for AI features) ─
OPENAI_API_KEY="sk-..."
ANTHROPIC_API_KEY="sk-ant-..."
GOOGLE_GEMINI_API_KEY="AIza..."

# ── App ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
